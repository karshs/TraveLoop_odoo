// ============================================================
//  TRAVELOOP — Complete Prisma Schema
//  PostgreSQL · Prisma ORM · Production-Ready
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum TripStatus {
  DRAFT
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

enum TripVisibility {
  PRIVATE
  PUBLIC
  LINK_ONLY
}

enum ActivityCategory {
  SIGHTSEEING
  FOOD_AND_DRINK
  ADVENTURE
  CULTURE
  SHOPPING
  WELLNESS
  NIGHTLIFE
  NATURE
  TRANSPORT
  ACCOMMODATION
  OTHER
}

enum BudgetCategory {
  TRANSPORT
  ACCOMMODATION
  FOOD
  ACTIVITIES
  SHOPPING
  MISC
}

enum ChecklistCategory {
  CLOTHING
  DOCUMENTS
  ELECTRONICS
  TOILETRIES
  MEDICINES
  ACCESSORIES
  MISC
}

enum NoteType {
  TRIP
  STOP
  DAY
}

enum OAuthProvider {
  GOOGLE
}

// ─────────────────────────────────────────────────────────────
//  USER
// ─────────────────────────────────────────────────────────────

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  firstName         String
  lastName          String
  phone             String?
  age               Int?
  password_hash     String?
  profile_photo_url String?
  language_pref     String         @default("en")
  role              Role           @default(USER)
  is_verified       Boolean        @default(false)
  is_deleted        Boolean        @default(false)  // soft delete

  // OAuth
  google_id         String?        @unique
  oauth_provider    OAuthProvider?

  // Password reset
  reset_token       String?        @unique
  reset_token_expiry DateTime?

  // Email verification
  verify_token      String?        @unique

  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  // Relations
  trips             Trip[]
  notes             TripNote[]
  checklist_items   ChecklistItem[]

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
//  CITY CATALOG  (pre-seeded, searchable)
// ─────────────────────────────────────────────────────────────

model City {
  id              String   @id @default(uuid())
  name            String
  country         String
  region          String?
  slug            String   @unique        // e.g. "paris-france"
  image_url       String?
  description     String?
  popularity_score Float   @default(0)   // 0–100, used for sorting
  avg_cost_per_day Float?                 // USD estimate per day
  latitude        Float?
  longitude       Float?
  is_active       Boolean  @default(true)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  stops           TripStop[]
  activities      Activity[]

  @@index([name, country])
  @@index([slug])
  @@index([country, region])
  @@map("cities")
}

// ─────────────────────────────────────────────────────────────
//  ACTIVITY CATALOG  (pre-seeded + user-created)
// ─────────────────────────────────────────────────────────────

model Activity {
  id            String           @id @default(uuid())
  city_id       String
  name          String
  description   String?
  category      ActivityCategory @default(SIGHTSEEING)
  image_url     String?
  estimated_cost Float           @default(0)   // per person, USD
  duration_hours Float?                         // estimated hours
  is_active     Boolean          @default(true)

  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  // Relations
  city          City             @relation(fields: [city_id], references: [id], onDelete: Cascade)
  stop_activities StopActivity[]

  @@index([city_id])
  @@index([category])
  @@index([city_id, category])
  @@map("activities")
}

// ─────────────────────────────────────────────────────────────
//  TRIP
// ─────────────────────────────────────────────────────────────

model Trip {
  id              String         @id @default(uuid())
  user_id         String
  title           String
  slug            String         @unique        // e.g. "europe-2026-abc123"
  description     String?
  cover_image_url String?
  start_date      DateTime?
  end_date        DateTime?
  status          TripStatus     @default(DRAFT)
  visibility      TripVisibility @default(PRIVATE)

  // Public sharing token — a separate random token for link-only share
  share_token     String?        @unique @default(uuid())

  // Budget cap set by user
  budget_limit    Float?

  is_deleted      Boolean        @default(false)  // soft delete

  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  // Relations
  user            User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  stops           TripStop[]
  budget_items    BudgetItem[]
  checklist_items ChecklistItem[]
  notes           TripNote[]

  @@index([user_id])
  @@index([visibility, is_deleted])
  @@index([share_token])
  @@index([slug])
  @@map("trips")
}

// ─────────────────────────────────────────────────────────────
//  TRIP STOP  (one city/destination within a trip)
// ─────────────────────────────────────────────────────────────

model TripStop {
  id            String   @id @default(uuid())
  trip_id       String
  city_id       String
  position      Int                         // display order; 1-based
  arrival_date  DateTime?
  departure_date DateTime?
  notes         String?                     // quick inline note

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  trip          Trip          @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  city          City          @relation(fields: [city_id], references: [id])
  stop_activities StopActivity[]
  trip_notes    TripNote[]

  @@unique([trip_id, position])            // enforce ordering uniqueness
  @@index([trip_id])
  @@index([city_id])
  @@map("trip_stops")
}

// ─────────────────────────────────────────────────────────────
//  STOP ACTIVITY  (junction: activities selected for a stop)
// ─────────────────────────────────────────────────────────────

model StopActivity {
  id              String   @id @default(uuid())
  stop_id         String
  activity_id     String
  scheduled_date  DateTime?           // which day to do it
  scheduled_time  String?             // "10:00 AM" – store as string for flexibility
  custom_cost     Float?              // override catalog cost
  duration_hours  Float?              // override catalog duration
  notes           String?
  position        Int      @default(0) // ordering within a stop's day

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  stop            TripStop  @relation(fields: [stop_id], references: [id], onDelete: Cascade)
  activity        Activity  @relation(fields: [activity_id], references: [id])

  @@unique([stop_id, activity_id])
  @@index([stop_id])
  @@index([activity_id])
  @@map("stop_activities")
}

// ─────────────────────────────────────────────────────────────
//  BUDGET ITEM  (individual expense line in a trip)
// ─────────────────────────────────────────────────────────────

model BudgetItem {
  id          String         @id @default(uuid())
  trip_id     String
  category    BudgetCategory
  label       String                           // e.g. "Flight BOM → CDG"
  amount      Float
  currency    String         @default("USD")
  is_actual   Boolean        @default(false)   // false = estimated, true = actual spent
  date        DateTime?                        // when the expense occurs

  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  // Relations
  trip        Trip           @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  @@index([trip_id])
  @@index([trip_id, category])
  @@map("budget_items")
}

// ─────────────────────────────────────────────────────────────
//  PACKING CHECKLIST ITEM
// ─────────────────────────────────────────────────────────────

model ChecklistItem {
  id          String            @id @default(uuid())
  trip_id     String
  user_id     String
  label       String
  category    ChecklistCategory @default(MISC)
  is_packed   Boolean           @default(false)
  position    Int               @default(0)    // display order

  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt

  // Relations
  trip        Trip              @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([trip_id])
  @@index([trip_id, category])
  @@map("checklist_items")
}

// ─────────────────────────────────────────────────────────────
//  TRIP NOTE / JOURNAL
// ─────────────────────────────────────────────────────────────

model TripNote {
  id        String   @id @default(uuid())
  trip_id   String
  user_id   String
  stop_id   String?                    // optional: note tied to a stop
  type      NoteType @default(TRIP)
  note_date DateTime?                  // optional: specific day this note is for
  title     String?
  content   String
  is_deleted Boolean @default(false)  // soft delete

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  trip      Trip      @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  stop      TripStop? @relation(fields: [stop_id], references: [id], onDelete: SetNull)

  @@index([trip_id])
  @@index([trip_id, stop_id])
  @@index([user_id])
  @@map("trip_notes")
}
